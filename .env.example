# ============================================================
# CS Agent Studio — environment configuration
# Copy this file to `.env` and fill in real values.
# `.env` is gitignored and must NEVER be committed.
# ============================================================

# --- GreenNode AgentBase credentials ---
GREENNODE_CLIENT_ID=
GREENNODE_CLIENT_SECRET=
# Optional: only needed when using agent identity features
GREENNODE_AGENT_IDENTITY=

# --- LLM access (GreenNode AI Platform — OpenAI-compatible) ---
LLM_BASE_URL=
LLM_API_KEY=

# --- Model tiering (model ids from the GreenNode catalogue) ---
# NOTE: the GreenNode /models list advertises many models, but only the ones your
# account/tier enables are actually servable. `google/gemma-4-31b-it` is the
# confirmed-working default; switch tiers to faster/stronger/vision models if your
# account has them enabled.
LLM_MODEL=google/gemma-4-31b-it
FAST_MODEL=google/gemma-4-31b-it
VISION_MODEL=google/gemma-4-31b-it
IDP_MODEL=greennode/idp
JUDGE_MODEL=google/gemma-4-31b-it

# --- Storage ---
DATABASE_URL=sqlite:///./data/cs_agent_studio.db

# --- Server ---
PORT=8080
HOST=0.0.0.0
# Comma-separated allowed CORS origins for the frontend dev server
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# --- Limits ---
MAX_UPLOAD_MB=32
CONTEXT_TOKEN_BUDGET=12000
